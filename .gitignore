# ========================================
# 自定义忽略的大文件和无关数据
# ========================================

# 1. 忽略所有权重模型文件 (绝对不能传)
*.pt
*.onnx
*.engine
*.weights

# 2. 忽略训练产生的所有日志和预测结果 (保持仓库干净)
runs/
wandb/

# 3. 忽略数据集、压缩包和测试图片 (体积太大)
*.zip
*.tar
*.gz
datasets/
data/images/
data/labels/
*.mp4
*.avi
*.jpg
*.png

# 4. 忽略 Python 的缓存文件
__pycache__/
*.pyc

# 5. 其他
ultralytics.egg-info/